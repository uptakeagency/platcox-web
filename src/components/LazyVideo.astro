---
interface Props {
  src: string;
  poster?: string;
  class?: string;
}

const { src, poster, class: className = "" } = Astro.props;
---

<video
  data-lazy-video
  data-src={src}
  autoplay
  muted
  loop
  playsinline
  preload="none"
  aria-hidden="true"
  poster={poster}
  class={`${className} motion-reduce:hidden`}
></video>

<script>
  // Lazy-load videos when they enter the viewport
  // Defers the entire MB-sized download until the user scrolls near them.
  const videos = document.querySelectorAll<HTMLVideoElement>("video[data-lazy-video]");

  if ("IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const video = entry.target as HTMLVideoElement;
            const src = video.dataset.src;
            if (src && !video.src) {
              video.src = src;
              video.load();
            }
            observer.unobserve(video);
          }
        });
      },
      { rootMargin: "200px" },
    );

    videos.forEach((v) => observer.observe(v));
  } else {
    // Fallback: load immediately if IntersectionObserver missing
    videos.forEach((v) => {
      const src = v.dataset.src;
      if (src) v.src = src;
    });
  }
</script>

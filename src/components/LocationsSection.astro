---
import ScrollReveal from "./ScrollReveal.tsx";
import WorldMap from "./WorldMap.tsx";
---

<section id="locations" class="bg-dark py-24 md:py-[160px] px-6 md:px-8">
  <div class="container-content">
    <ScrollReveal client:visible animation="fade-up">
      <p class="text-[11px] font-medium uppercase tracking-[3px] text-[#999] mb-4">OUR LOCATIONS</p>
      <h2 class="text-3xl font-light tracking-tight text-white md:text-5xl">Global presence.</h2>
    </ScrollReveal>

    <div class="mt-16">
      <WorldMap client:visible />
    </div>
  </div>
</section>

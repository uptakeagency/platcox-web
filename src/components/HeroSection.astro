---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section id="hero" class="relative flex min-h-screen flex-col items-center justify-center px-6">
  <!-- Product Mockup -->
  <ScrollReveal client:visible animation="scale-up" duration={1}>
    <div class="mb-16 w-full max-w-3xl">
      <div class="rounded-t-lg bg-dark p-1">
        <div class="flex gap-1.5 px-2 py-1.5">
          <div class="h-2.5 w-2.5 rounded-full bg-white/20"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-white/20"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-white/20"></div>
        </div>
      </div>
      <div class="rounded-b-lg bg-[#0a0a1a] p-8">
        <div class="grid grid-cols-4 gap-3">
          {Array.from({ length: 8 }).map(() => (
            <div class="h-16 rounded bg-white/5 p-2">
              <div class="mb-2 h-2 w-3/4 rounded bg-white/10"></div>
              <div class="h-1.5 w-1/2 rounded bg-accent/20"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </ScrollReveal>

  <!-- Heading -->
  <ScrollReveal client:visible animation="fade-up" delay={0.3} duration={0.8}>
    <h1 class="text-center text-5xl font-light leading-tight tracking-tight md:text-7xl lg:text-[96px] lg:leading-[1.05] lg:tracking-[-2px]">
      Where Global Trade<br />
      Gets Rede<span class="font-semibold">fined</span>
    </h1>
  </ScrollReveal>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-12 flex flex-col items-center gap-2">
    <span class="text-xs text-muted">Scroll to Explore</span>
    <div class="animate-bounce text-muted">&darr;</div>
  </div>
</section>

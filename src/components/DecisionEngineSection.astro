---
import ScrollReveal from "./ScrollReveal.tsx";
import DecisionEngineDemo from "./DecisionEngineDemo.tsx";
---

<section id="decision-engine" class="section-padding bg-zinc-50/50">
  <div class="container-content">
    <ScrollReveal client:visible animation="fade-up">
      <div class="flex flex-col md:flex-row justify-between items-end gap-8">
        <div class="max-w-2xl">
          <p class="section-label">INTELLIGENT OPERATIONS</p>
          <h2 class="text-3xl font-light tracking-tight md:text-5xl">
            C.O.D.E Decision Engine
          </h2>
          <p class="mt-6 text-muted">
            Global trade requires unparalleled visibility. Our proprietary Decision Engine (Live Tracking) integrates AI analytics, video feeds, and real-time operational data into a single pane of glass — giving you the power to optimize performance instantly from anywhere.
          </p>
        </div>
      </div>
    </ScrollReveal>

    <ScrollReveal client:visible animation="fade-up" delay={0.2}>
      <DecisionEngineDemo client:visible />
    </ScrollReveal>
  </div>
</section>
